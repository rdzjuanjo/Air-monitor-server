# InfluxDB 2.x
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=replace-with-token
INFLUX_ORG=riosvivos
INFLUX_BUCKET=ambiental

# Data schema (escrito por telegraf, ver Docker/telegraf/telegraf.conf)
INFLUX_MEASUREMENT=env_monitoring
INFLUX_STATION_TAG=device_id
INFLUX_VALUE_FIELD=cvol
INFLUX_LAT_FIELD=lat
INFLUX_LON_FIELD=lon

# Dashboard
DASHBOARD_WINDOW_HOURS=24
DASHBOARD_STEP_MINUTES=20
