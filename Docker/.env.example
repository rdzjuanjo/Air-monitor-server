# Dominio base (usado por nginx/certbot)
DOMAIN=sensio.mx
LETSENCRYPT_EMAIL=admin@sensio.mx

# Perfil de nginx: "vps" (HTTPS + certbot, usa DOMAIN como dominio publico)
# o "lan" (HTTP plano via mDNS, usa DOMAIN=dash.local)
NGINX_PROFILE=vps

# InfluxDB
INFLUX_ORG=riosvivos
INFLUX_BUCKET=ambiental
INFLUX_BUCKET_SYSTEM=sistema
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me-influx-admin
INFLUX_TOKEN=change-me-influx-token

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# Alertas de Grafana via Telegram (monitoreo del servidor)
TELEGRAM_BOT_TOKEN=change-me-telegram-bot-token
TELEGRAM_CHAT_ID=change-me-telegram-chat-id

# Panel de administracion (Flask)
ADMIN_SECRET_KEY=change-me-flask-secret

# OTA (firmware ESP32) - URL base donde se sirve narizdigital.json/.bin
OTA_BASE_URL=https://ota.sensio.mx
